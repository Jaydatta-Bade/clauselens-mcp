# WorkOS AuthKit — get these from workos.com → AuthKit → Applications
WORKOS_CLIENT_ID=client_01REPLACE_WITH_YOUR_CLIENT_ID
WORKOS_JWKS_URI=https://api.workos.com/sso/jwks/client_01REPLACE_WITH_YOUR_CLIENT_ID
WORKOS_AUDIENCE=clauselens
WORKOS_ISSUER=https://api.workos.com

# Rate limiting (optional — defaults shown)
RATELIMIT_REQUESTS=10
RATELIMIT_WINDOW_SECONDS=3600

# Server
PORT=8000
MCP_PUBLIC_URL=https://YOUR-SUBDOMAIN.railway.app/mcp
